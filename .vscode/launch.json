{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Project Pulse Dashboard",
      "type": "python",
      "request": "launch",
      "module": "http.server",
      "args": ["5500"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/app",
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Serving HTTP on .* port (\\d+)",
        "uriFormat": "http://localhost:%s/index.html"
      }
    }
  ]
}
